        1. Let _calendar_ be ? ToTemporalCalendarIdentifier(_calendarLike_).
        1. Return ! CreateTemporalDateTime(_plainDateTime_.[[ISODateTime]], _calendar_).
      </emu-alg>
    </emu-clause>

